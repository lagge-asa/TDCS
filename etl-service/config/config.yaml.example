# ETL 服务配置文件示例
# 复制为 config.yaml 并填写实际值
# 密码/密钥必须通过环境变量提供, 不可明文写入

service:
  instance_id: "${HOSTNAME}_${PID}"
  log_level: "INFO"

database:
  master:
    host: "127.0.0.1"
    port: 3306
    user: "etl_user"
    password: "${DB_MASTER_PASSWORD}"
    database: "etl_db"
    pool_size: 5
    pool_timeout: 30
    pool_recycle: 3600
    connect_timeout: 10
    auth_plugin: "caching_sha2_password"
  slaves: []

cache:
  local:
    enabled: true
    maxsize: 1000
    ttl: 300
  redis:
    enabled: false
    host: "127.0.0.1"
    port: 6379
    password: "${REDIS_PASSWORD}"
    db: 0

concurrency:
  worker_threads: 4
  queue_maxsize: 500
  task_timeout: 300

encryption:
  enabled: false
  algorithm: "fernet"
  key_env: "ETL_ENCRYPTION_KEY"

high_availability:
  enabled: false
  heartbeat_interval: 10
  failover_timeout: 30
  degraded_mode: "pause"   # pause | standalone

web:
  enabled: true
  host: "127.0.0.1"
  port: 8080
  secret_key: "${WEB_SECRET_KEY}"
  token_expire_hours: 8
  rate_limit: "200 per minute"
  server: "waitress"
  threads: 4

monitoring:
  prometheus:
    enabled: true
    port: 9090
  alerting:
    enabled: false
    channels:
      - type: "dingtalk"
        webhook: "${DINGTALK_WEBHOOK}"
        secret: "${DINGTALK_SECRET}"
    rules:
      failed_files_threshold: 10
      quality_score_min: 80.0
      queue_size_max: 400

tasks:
  - task_id: "order_import"
    name: "订单数据导入"
    enabled: true
    priority: 1
    monitor:
      folder_path: "D:\\data\\orders"
      file_extensions: [".csv"]
      recursive: false
      debounce_seconds: 3
      stability_check_interval: 1
      stability_check_count: 3
    etl:
      extractor: "csv"
      encoding: "auto"
      stream_threshold_mb: 100
      batch_size: 1000
      transformer_module: "custom_etl.order_cleaner"
      transformer_function: "transform"
      sandbox_timeout: 30
      sandbox_memory_mb: 256
    table:
      base_table: "order_data"
      partition_field: "business_date"
      partition_field_format: "%Y-%m-%d"
      create_table_template: "sql_templates/order_template.sql"
      retention_months: 24
      archive_old_tables: true
    error_handling:
      max_retries: 3
      retry_backoff: [5, 30, 120]
      dead_letter_dir: "D:\\dead_letters\\orders"
      on_row_error: "skip"
    archive:
      mode: "move"
      archive_dir: "D:\\archive\\orders"
      retain_structure: true
      compress_after_days: 7
      cleanup_after_days: 90
    schedule:
      poll_interval: 60
      poll_incremental: true
